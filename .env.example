# Local binding and Docker host ports
BIND_HOST=127.0.0.1
MONGO_HOST_PORT=27017
BACKEND_DOCKER_PORT=8081
CLIENT_DOCKER_PORT=3001
ADMIN_DOCKER_PORT=8001


# Application ports
BACKEND_PORT=5000
CLIENT_INTERNAL_PORT=3000
ADMIN_INTERNAL_PORT=8000


# Database
MONGO_URI=mongodb://localhost:27017
MONGO_DOCKER_URI=mongodb://mongodb:27017
DB_NAME=vocab_battle_dev

# Local development URLs
DEV_NEXT_PUBLIC_API_URL=http://localhost:5000
DEV_NEXT_PUBLIC_WS_URL=ws://localhost:5000

# Production URLs embedded in the client image
NEXT_PUBLIC_API_URL=https://api.urms.io.vn
NEXT_PUBLIC_WS_URL=wss://api.urms.io.vn

# AES-256-GCM obfuscation for GET /api/cards only. Generate once, then use the
# same Base64-encoded 32-byte value (or 64-character hex value) for backend
# and both client builds.
ENCRYPTION_KEY=

# Backend runtime
GIN_MODE=release
ADMIN_OTP=031024

# Cloudflare R2 (server-only; do not prefix these with NEXT_PUBLIC_)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=vocab-battle
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://<your-public-r2-domain>
R2_UPLOAD_PREFIX=uploads
R2_PRESIGNED_URL_TTL_SECONDS=300
